# ========================================
# ESP32 NFC 云门禁系统 - Docker环境变量
# ========================================
# 用于docker-compose.yml配置
# 使用方法：复制为.env文件并修改相应值
# ========================================

# ----------------------------------------
# 数据库配置
# ----------------------------------------
# PostgreSQL密码（生产环境必须修改）
DB_PASSWORD=change_this_strong_password_in_production

# ----------------------------------------
# JWT配置
# ----------------------------------------
# JWT密钥（生产环境必须修改为强随机字符串）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your_random_secret_key_min_32_chars_change_this_in_production

# ----------------------------------------
# CORS配置
# ----------------------------------------
# 允许的前端域名（多个域名用逗号分隔）
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ----------------------------------------
# Redis配置（可选）
# ----------------------------------------
# Redis密码
REDIS_PASSWORD=redis_strong_password

# ----------------------------------------
# 域名配置（生产环境）
# ----------------------------------------
# 您的域名
DOMAIN=access.yourdomain.com

# ----------------------------------------
# 邮件配置（可选）
# ----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@yourdomain.com
