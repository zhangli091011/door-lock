# ========================================
# ESP32 NFC 云门禁系统 - 环境变量配置
# ========================================

# ----------------------------------------
# 数据库配置
# ----------------------------------------
# 数据库类型：sqlite（本地开发）或 postgresql（生产环境）
DATABASE_TYPE=sqlite

# SQLite配置（当DATABASE_TYPE=sqlite时使用）
DATABASE_PATH=./data/access_control.db

# PostgreSQL配置（当DATABASE_TYPE=postgresql时使用）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgresql://access_user:your_strong_password@localhost:5432/access_control

# ----------------------------------------
# 服务器配置
# ----------------------------------------
# 服务器监听端口
PORT=3000

# 运行环境：development（开发）或 production（生产）
NODE_ENV=development

# 服务器主机地址（0.0.0.0表示监听所有网络接口）
HOST=0.0.0.0

# ----------------------------------------
# JWT认证配置
# ----------------------------------------
# JWT密钥（生产环境必须修改为强随机字符串，至少32字符）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_min_32_chars_change_this_in_production

# JWT令牌有效期（24h=24小时，7d=7天）
JWT_EXPIRES_IN=24h

# ----------------------------------------
# CORS跨域配置
# ----------------------------------------
# 允许的前端域名，多个域名用逗号分隔
# 开发环境示例：http://localhost:8080,http://localhost:3000
# 生产环境示例：https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ----------------------------------------
# 速率限制配置
# ----------------------------------------
# 每分钟每设备最大请求数（防止设备异常频繁请求）
RATE_LIMIT_DEVICE=60

# 每分钟每IP最大请求数（防止DDoS攻击）
RATE_LIMIT_IP=100

# ----------------------------------------
# 日志配置
# ----------------------------------------
# 日志级别：error, warn, info, debug
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/app.log

# 是否在控制台输出日志（开发环境建议true，生产环境建议false）
LOG_CONSOLE=true

# ----------------------------------------
# HTTPS/SSL配置（生产环境）
# ----------------------------------------
# 是否启用HTTPS（生产环境建议true）
ENABLE_HTTPS=false

# SSL证书路径（使用Let's Encrypt或自签名证书）
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ----------------------------------------
# Redis缓存配置（可选，用于分布式部署）
# ----------------------------------------
# 是否启用Redis缓存
ENABLE_REDIS=false

# Redis服务器地址
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ----------------------------------------
# 邮件通知配置（可选，用于告警通知）
# ----------------------------------------
# 是否启用邮件通知
ENABLE_EMAIL=false

# SMTP服务器配置
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# 告警接收邮箱
# ALERT_EMAIL=admin@yourdomain.com

# ----------------------------------------
# 系统配置
# ----------------------------------------
# 访问日志保留天数（超过此天数的日志将被自动清理）
LOG_RETENTION_DAYS=90

# 设备离线判定时间（分钟，超过此时间未上报视为离线）
DEVICE_OFFLINE_MINUTES=5

# 缓存过期时间（秒，ESP32本地缓存的有效期）
CACHE_EXPIRE_SECONDS=86400

# ----------------------------------------
# 安全配置
# ----------------------------------------
# 请求签名时间戳容差（秒，防重放攻击）
SIGNATURE_TIMESTAMP_TOLERANCE=300

# 密码哈希强度（bcrypt rounds，建议10-12）
BCRYPT_ROUNDS=10

# ----------------------------------------
# 监控配置（可选）
# ----------------------------------------
# 是否启用性能监控
ENABLE_MONITORING=false

# 监控数据上报地址
# MONITORING_URL=https://your-monitoring-service.com/api/metrics

# ----------------------------------------
# 备份配置（可选）
# ----------------------------------------
# 是否启用自动备份
ENABLE_AUTO_BACKUP=false

# 备份目录
# BACKUP_DIR=./backups

# 备份间隔（小时）
# BACKUP_INTERVAL_HOURS=24

# 备份保留数量
# BACKUP_RETENTION_COUNT=7
