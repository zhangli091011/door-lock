# Root level gitignore

# Environment files
.env
.env.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# OS files
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Kiro specs
.kiro/

# Node modules
node_modules/

# Build outputs
dist/
build/
coverage/

# Database files
*.sqlite
*.db

# Test files
test-*.js
*-test.js
simulate-*.js
debug-*.js
