# ========================================
# ESP32 NFC 云门禁系统 - 开发环境Docker镜像
# ========================================
# 支持热重载和调试
# ========================================

FROM node:18-alpine

# 安装开发工具
RUN apk add --no-cache \
    curl \
    git

# 设置工作目录
WORKDIR /app

# 复制package文件
COPY server/package*.json ./

# 安装所有依赖（包括开发依赖）
RUN npm install

# 复制源代码
COPY server/ ./

# 暴露端口
EXPOSE 3000 9229

# 启动开发服务器（支持热重载）
CMD ["npm", "run", "dev"]
