# 数据库配置
# 数据库类型：sqlite 或 postgresql
DATABASE_TYPE=sqlite

# SQLite配置（当DATABASE_TYPE=sqlite时使用）
DATABASE_PATH=./data/access_control.db

# PostgreSQL配置（当DATABASE_TYPE=postgresql时使用）
# DATABASE_URL=postgresql://access_user:your_password@localhost:5432/access_control

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
# 请使用强随机字符串（至少32字符）
JWT_SECRET=your_random_secret_key_min_32_chars_change_this_in_production
JWT_EXPIRES_IN=24h

# CORS配置
# 允许的前端域名，多个域名用逗号分隔
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# 速率限制配置
# 每分钟每设备最大请求数
RATE_LIMIT_DEVICE=60
# 每分钟每IP最大请求数
RATE_LIMIT_IP=100

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 缓存配置（可选，用于Redis）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# HTTPS配置（生产环境）
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# 邮件通知配置（可选）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# 告警配置（可选）
# ALERT_EMAIL=admin@yourdomain.com
